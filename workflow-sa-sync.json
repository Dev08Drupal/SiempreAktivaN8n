        "options": {}
      },
      "id": "sa-0003-0003-0003-sa00030003",
      "name": "Rechazar — 401",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [680, 480]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\n// Formatear precio COP\nconst precio = new Intl.NumberFormat('es-CO', {\n  style: 'currency',\n  currency: 'COP',\n  maximumFractionDigits: 0\n}).format(d.precio);\n\n// Caption Instagram (max 2200 chars)\nlet caption_ig = `✨ *${d.titulo}*\\n\\n`;\ncaption_ig += d.es_oferta\n  ? `🔥 OFERTA: ${precio} (${d.descuento}% OFF)\\n\\n`\n  : `💰 Precio: ${precio}\\n\\n`;\ncaption_ig += `${d.descripcion || ''}\\n\\n`;\ncaption_ig += `📲 Escríbenos para pedirlo\\n`;\ncaption_ig += `#${d.categoria} #siempreaktiva #tienda #moda`;\n\n// Texto Facebook\nlet texto_fb = `🛍️ ${d.titulo}\\n\\n`;\ntexto_fb += d.es_oferta\n  ? `🔥 OFERTA ESPECIAL: ${precio} (${d.descuento}% de descuento)\\n\\n`\n  : `Precio: ${precio}\\n\\n`;\ntexto_fb += `${d.descripcion || ''}\\n\\n`;\ntexto_fb += `💬 Escríbenos por WhatsApp o en los comentarios`;\n\nreturn [{\n  json: {\n    ...d,\n    precio_formateado: precio,\n    caption_ig,\n    texto_fb\n  }\n}];"
      },
      "id": "sa-0004-0004-0004-sa00040004",
      "name": "Transformar Datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "evento-nuevo",
              "leftValue": "={{ $json.evento }}",
              "rightValue": "producto_nuevo",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "sa-0005-0005-0005-sa00050005",
