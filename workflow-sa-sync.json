        "url": "=https://siempreaktiva.ddev.site/jsonapi/node/producto/{{ $('Transformar Datos').item.json.uuid }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/vnd.api+json" },
            { "name": "Authorization", "value": "=Basic {{ $env.DRUPAL_B64 }}" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"data\": {\n    \"type\": \"node--producto\",\n    \"id\": \"{{ $('Transformar Datos').item.json.uuid }}\",\n    \"attributes\": {\n      \"field_fb_post_id\": \"{{ $('FB — Publicar Foto').item.json.id }}\",\n      \"field_ig_media_id\": \"{{ $('IG — Publicar').item.json.id }}\",\n      \"field_pub_estado\": \"publicado\"\n    }\n  }\n}",
        "options": {}
      },
