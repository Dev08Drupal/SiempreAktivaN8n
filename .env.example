# ─── Base de datos LOCAL (Docker) ────────────────────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=n8n

# ─── n8n ─────────────────────────────────────────────────────────────────────
# Genera una clave aleatoria: openssl rand -hex 16
N8N_ENCRYPTION_KEY=pon_aqui_una_clave_de_32_caracteres

N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# ─── PRODUCCIÓN en Render (llenar al desplegar) ───────────────────────────────
# Estas variables las configuras en el dashboard de Render, NO aquí:
#
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=<host-de-nhost>
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=<db-de-nhost>
# DB_POSTGRESDB_USER=<user-de-nhost>
# DB_POSTGRESDB_PASSWORD=<password-de-nhost>
# N8N_HOST=<tu-app>.onrender.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://<tu-app>.onrender.com
# N8N_ENCRYPTION_KEY=<misma-clave-que-local>
